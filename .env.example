# ── Apify (substitui SerpAPI para scraping Google Maps) ───────────────────────
APIFY_TOKEN=sua_chave_aqui            # apify.com → Settings → Integrations → API Token

# ── SerpAPI (desativado — mantido para referência) ────────────────────────────
# SERP_API_KEY=sua_chave_aqui

# ── Google Sheets API (Service Account) ────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SHEET_ID=1r7vob1TvEY8P9G6wm5NcfNFg_r1aUwqvBSS7mrSt9Oo
SHEET_TAB=Página1

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGIN=https://pedrooalencar13.github.io

# ── Segurança: chave secreta da API (obrigatória em produção) ──────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Adicione o mesmo valor no Render (Environment → API_SECRET)
# /ping e /health ficam públicos (usados pelo cron-job.org e Render health checks)
API_SECRET=sua-chave-secreta-aqui

# ── Controle do scraper ────────────────────────────────────────────────────────
SCRAPER_DELAY_MS=2500
SCRAPER_MAX_PER_RUN=50
SCRAPER_CRON=0 */6 * * *

# ── Gmail OAuth2 (para envio direto via API sem abrir abas) ────────────────────
# Como obter:
# 1. console.cloud.google.com → APIs & Services → Credentials
# 2. Crie OAuth 2.0 Client ID (tipo "Desktop App")
# 3. Ative a Gmail API no projeto
# 4. Acesse https://developers.google.com/oauthplayground/
#    → clique no ícone de engrenagem → "Use your own OAuth credentials"
#    → cole client_id e client_secret
#    → em "Select & authorize APIs" selecione: https://mail.google.com/
#    → clique "Authorize APIs" → faça login → "Exchange authorization code for tokens"
#    → copie o "Refresh token"
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=pedrooalencar13@gmail.com

# ── Claude API (para gerar e-mails de cadência no backend) ─────────────────────
# Obtenha em: console.anthropic.com → API Keys
CLAUDE_API_KEY=

# ── Tracking ───────────────────────────────────────────────────────────────────
# URL pública do Railway (usada nos pixels de tracking dos e-mails)
BACKEND_PUBLIC_URL=https://matte-ia.onrender.com
